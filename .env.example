# Saltwater Studio — environment variables
# Copy to .env.local for local development.
# Production values live in the Vercel dashboard — never commit real values.

# Resend (email delivery for quote form)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address that receives quote form submissions
STUDIO_EMAIL=hello@saltwaterstudio.xyz

# Google Tag Manager container ID (public — prefix NEXT_PUBLIC_)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
